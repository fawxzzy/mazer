VITE_SUPABASE_URL=
# Use the Mazer project's browser-safe publishable key here.
# Do not put service-role or secret keys in VITE_* browser env vars.
VITE_SUPABASE_ANON_KEY=

# Optional exact Auth callback ownership. Leave blank to use the current exact
# same-origin Mazer compatibility routes until account.fawxzzy.com is live.
# Wildcards and URL fragments are rejected by the client contract.
VITE_MAZER_AUTH_CONFIRMATION_REDIRECT_URL=
VITE_MAZER_AUTH_RECOVERY_REDIRECT_URL=

# Disabled by default. "read-write" exposes the future global username metadata
# slot without enabling username login or claiming uniqueness.
VITE_MAZER_PLATFORM_USERNAME_CAPABILITY=disabled

# Optional. Requires the Supabase migration in supabase/migrations to be applied.
VITE_MAZER_REMOTE_PROGRESSION=false
