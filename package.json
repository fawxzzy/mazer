{
  "name": "mazer",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node ./scripts/build/run-build.mjs",
    "build:raw": "tsc --noEmit && vite build",
    "preview": "vite preview --host 0.0.0.0 --port 4173 --strictPort",
    "preview:health": "vite preview --strictPort",
    "verify": "node ./scripts/verify/run-verify.mjs",
    "verify:fast": "node ./scripts/verify/run-fast-verify.mjs",
    "verify:fast:tests": "node ./scripts/verify/run-fast-verify.mjs --skip-lint",
    "verify:fast:all": "node ./scripts/verify/run-fast-verify.mjs --all",
    "verify:local": "node ./scripts/verify/run-playbook-local-verify.mjs",
    "health": "node ./scripts/gates/future-lane-health.mjs",
    "legacy:extract": "node ./scripts/legacy/extract-legacy-truth.mjs",
    "gate:future-lane": "node ./scripts/gates/future-lane-health.mjs",
    "test": "vitest run tests/reset tests/ai/demo-walker.test.ts tests/ai/demo-walker-known-frontier.test.ts tests/ai/demo-walker-rank-ladder.test.ts tests/ai/demo-walker-recovery-diagnostics.test.ts tests/scenes/menu-render-frame.test.ts tests/analysis/maze-cycle-telemetry-report.test.mjs",
    "test:verify": "vitest run tests/reset tests/ai/demo-walker.test.ts tests/ai/demo-walker-known-frontier.test.ts tests/ai/demo-walker-rank-ladder.test.ts tests/ai/demo-walker-recovery-diagnostics.test.ts tests/scenes/menu-render-frame.test.ts tests/analysis/maze-cycle-telemetry-report.test.mjs --maxWorkers 1",
    "test:architecture": "vitest run tests/architecture",
    "architecture:check": "node ./scripts/check-architecture.mjs",
    "test:soak": "vitest run tests/maze/maze-soak.test.ts",
    "lint": "tsc --noEmit",
    "test:playbook-adoption": "vitest run tests/playbook-adoption-evidence.test.mjs",
    "test:playbook-verification": "vitest run tests/playbook-verification-report.test.mjs",
    "visual:capture": "node ./scripts/visual/capture.mjs",
    "visual:matrix": "node ./scripts/visual/capture-layout-matrix.mjs",
    "visual:matrix:recovery": "node ./scripts/visual/capture-layout-matrix.mjs --preset core --design recovery",
    "visual:matrix:url": "node ./scripts/visual/capture-layout-matrix.mjs",
    "edge:live": "node --experimental-strip-types ./scripts/visual/edge-live-check.mjs",
    "edge:live:recovery:watch": "node --experimental-strip-types ./scripts/visual/edge-live-check.mjs --run core-only-watch-recovery",
    "edge:live:recovery:play": "node --experimental-strip-types ./scripts/visual/edge-live-check.mjs --run core-only-play-recovery",
    "visual:gate": "node ./scripts/visual/gate.mjs",
    "visual:index": "node ./scripts/visual/index-artifacts.mjs",
    "visual:compare": "node ./scripts/visual/index-artifacts.mjs --compare",
    "visual:promote-baseline": "node ./scripts/visual/index-artifacts.mjs --promote-baseline",
    "visual:regressions": "node ./scripts/visual/index-artifacts.mjs --regressions",
    "visual:proof": "node ./scripts/visual/mazer-run.mjs",
    "visual:canaries": "node ./scripts/visual/run-canaries.mjs",
    "boot:timing": "node ./scripts/analysis/capture-boot-timing.mjs",
    "projection:export-pack": "node --experimental-strip-types ./scripts/projections/export-native-payloads.mjs",
    "runtime:observe": "node --experimental-strip-types ./scripts/analysis/capture-runtime-observe.mjs",
    "cycle:report": "node ./scripts/analysis/maze-cycle-telemetry-report.mjs",
    "ai:calibrate": "vite-node ./scripts/analysis/ai-runner-calibration.ts",
    "ai:calibrate:fast": "vite-node ./scripts/analysis/ai-runner-calibration.ts --summary-only --scales=37 --seeds=1,2,3,5,8",
    "ai:calibrate:biases": "vite-node ./scripts/analysis/ai-runner-calibration.ts --summary-only --bias-sweep",
    "ai:calibrate:ranks": "vite-node ./scripts/analysis/ai-runner-calibration.ts --summary-only --rank-sweep",
    "ai:calibrate:ranks:fast": "vite-node ./scripts/analysis/ai-runner-calibration.ts --summary-only --rank-sweep --scales=37 --seeds=1,2,3,5,8",
    "live:menu-ai-qa": "node ./scripts/analysis/live-menu-ai-qa.mjs",
    "live:play-qa": "node ./scripts/analysis/live-play-qa.mjs",
    "visual:ui-surfaces": "node ./scripts/analysis/capture-ui-surfaces.mjs",
    "runtime:soak": "node ./scripts/analysis/capture-runtime-soak.mjs",
    "runtime:soak:10m": "node ./scripts/analysis/capture-runtime-soak.mjs --duration-seconds 600 --label 10m --restart-cycles 3 --restart-mode route-reset --hidden-window-ms 30000",
    "runtime:soak:30m": "node ./scripts/analysis/capture-runtime-soak.mjs --duration-seconds 1800 --label 30m --restart-cycles 6 --restart-mode route-reset --hidden-window-ms 60000",
    "future:content-proof": "node ./scripts/visual/future-runtime-run.mjs --run content-proof",
    "future:two-shell-proof": "node ./scripts/visual/future-runtime-run.mjs --run two-shell-proof",
    "future:three-shell-proof": "node ./scripts/visual/future-runtime-run.mjs --run three-shell-proof",
    "eval:runtime": "node ./scripts/eval/run-eval.mjs",
    "lifeline:headless-smoke": "node ./scripts/lifeline/headless-runner.mjs --scenario labyrinth-tutorial-trap-inference-alpha --run gate-pack-headless-smoke --output-root tmp/lifeline/headless-runner/gate-pack-headless-smoke --blessed true",
    "topology:export": "node ./scripts/topology/export-proof-manifests.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "2.75.0",
    "phaser": "^3.90.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "playwright": "^1.59.1",
    "supabase": "^2.109.1",
    "typescript": "^5.8.3",
    "vite": "^7.0.0",
    "vite-plugin-pwa": "^1.0.2",
    "vitest": "^3.2.4"
  }
}
